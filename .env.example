# ---------------------------------------------------------------------------
# Frontend env template. Copy to `.env` (or `.env.local`).
#
# Cognito is used ONLY for authentication (sign-in, sign-up, AdminCreateUser
# during invite). Roles and org membership live in Postgres and are fetched
# through /api/users/me.
# ---------------------------------------------------------------------------

# --- Cognito (auth only) ----------------------------------------------------
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-southeast-2_REPLACE
NEXT_PUBLIC_COGNITO_CLIENT_ID=REPLACE_APP_CLIENT_ID
COGNITO_USER_POOL_ID=ap-southeast-2_REPLACE

# --- AWS (needed for Cognito AdminCreateUser and optional RDS IAM auth) -----
# Prefixed APP_ instead of AWS_ because AWS deployment runtimes (App Runner,
# Lambda, Amplify) reserve the AWS_ prefix for system-injected env vars and
# reject user-set values starting with AWS_. On AWS, attach an IAM role to
# the runtime instead of setting APP_ACCESS_KEY_ID / APP_SECRET_ACCESS_KEY.
APP_REGION=ap-southeast-2
APP_ACCESS_KEY_ID=REPLACE
APP_SECRET_ACCESS_KEY=REPLACE

# --- Core API (Go backend) --------------------------------------------------
# Point both at the local backend when running `go run ./cmd/server`.
CORE_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_CORE_API_BASE_URL=http://localhost:8080

# --- Database (direct-DB fallback for routes not yet on the Go API) ---------
# For local dev these should point at the docker-compose Postgres.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_NAME=cleartax
DATABASE_PASSWORD=postgres
